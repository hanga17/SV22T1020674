@model SV22T1020674.Models.Partner.Customer

<style>
    /* WRAPPER */
    .profile-wrapper {
        max-width: 600px;
        margin: 40px auto;
    }

    /* TITLE */
    .profile-title {
        text-align: center;
        color: #5a3e2b;
        margin-bottom: 20px;
    }

    /* CARD */
    .profile-card {
        background: #fff;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        animation: fadeIn 0.5s ease;
    }

    /* ITEM */
    .profile-item {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 10px;
        padding: 12px 0;
        border-bottom: 1px solid #eee;
        align-items: center;
        transition: 0.3s;
    }

        .profile-item:hover {
            background: #f9f6f0;
            border-radius: 6px;
        }

    .profile-label {
        font-weight: bold;
        color: #5a3e2b;
    }

    .profile-value {
        color: #444;
        font-weight: 500;
    }

    /* BUTTON */
    .btn-custom {
        display: inline-block;
        margin-top: 20px;
        background: linear-gradient(45deg, #c9a66b, #a67c52);
        color: white;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-custom:hover {
            background: #8b5e3c;
            transform: translateY(-2px);
        }

    /* BUTTON GROUP */
    .btn-group {
        text-align: center;
        margin-top: 20px;
    }

        .btn-group a {
            margin: 5px;
        }

    /* ALERT */
    .alert-success {
        background: #d4edda;
        color: #155724;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 15px;
        text-align: center;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 15px;
        text-align: center;
    }

    /* ANIMATION */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="profile-wrapper">

    <!-- MESSAGE -->
    @if (TempData["Success"] != null)
    {
        <div id="msg" class="alert-success">
            @TempData["Success"]
        </div>

        <script>
                setTimeout(function () {
                    var msg = document.getElementById("msg");
                    if (msg) msg.style.display = "none";
                }, 3000);
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert-error">
            @TempData["Error"]
        </div>
    }

    <h2 class="profile-title">Hồ sơ cá nhân</h2>

    @if (Model != null)
    {
        <div class="profile-card">

            <div class="profile-item">
                <span class="profile-label">Họ tên:</span>
                <span class="profile-value">@Model.CustomerName</span>
            </div>

            <div class="profile-item">
                <span class="profile-label">Email:</span>
                <span class="profile-value">@Model.Email</span>
            </div>

            <div class="profile-item">
                <span class="profile-label">SĐT:</span>
                <span class="profile-value">@Model.Phone</span>
            </div>

            <div class="profile-item">
                <span class="profile-label">Địa chỉ:</span>
                <span class="profile-value">@Model.Address</span>
            </div>

            <!-- BUTTONS -->
            <div class="btn-group">
                <a asp-action="ChangePassword" class="btn-custom">
                    Đổi mật khẩu
                </a>

                <a href="/Account/EditProfile" class="btn-custom">
                    Chỉnh sửa hồ sơ
                </a>
            </div>

        </div>
    }
    else
    {
        <p class="alert-error">Không có dữ liệu</p>
    }

</div>
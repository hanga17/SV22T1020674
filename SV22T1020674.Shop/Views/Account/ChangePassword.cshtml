<style>
    /* WRAPPER */
    .change-pass-wrapper {
        max-width: 450px;
        margin: 50px auto;
    }

    /* CARD */
    .change-pass-card {
        background: #fff;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        animation: fadeIn 0.5s ease;
    }

    /* TITLE */
    .change-pass-title {
        text-align: center;
        color: #5a3e2b;
        margin-bottom: 20px;
    }

    /* INPUT */
    .change-pass-card input {
        width: 100%;
        padding: 10px;
        margin-bottom: 12px;
        border-radius: 8px;
        border: 1px solid #ccc;
        transition: 0.3s;
    }

        .change-pass-card input:focus {
            border-color: #c9a66b;
            outline: none;
            box-shadow: 0 0 5px rgba(201,166,107,0.5);
        }

    /* BUTTON */
    .btn-custom {
        width: 100%;
        background: linear-gradient(45deg, #c9a66b, #a67c52);
        color: white;
        border: none;
        padding: 10px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-custom:hover {
            background: #8b5e3c;
            transform: translateY(-2px);
        }

    /* ANIMATION */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    /* BACK LINK */
    .back-link {
        text-align: center;
        margin-top: 15px;
    }

        .back-link a {
            color: #a67c52;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

            .back-link a:hover {
                color: #ffd700;
            }
</style>

<form method="post" class="change-pass-wrapper">

    <div class="change-pass-card">

        <h2 class="change-pass-title">🔒 Đổi mật khẩu</h2>

        <input name="oldPassword" placeholder="Mật khẩu cũ" />

        <input name="newPassword" placeholder="Mật khẩu mới" type="password" />

        <button class="btn-custom">
             Cập nhật
        </button>
        <div class="back-link">
            <a href="/Account/Profile">← Quay lại hồ sơ</a>
        </div>

    </div>

</form>
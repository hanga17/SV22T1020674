@model IEnumerable<SV22T1020674.Models.Catalog.Product>
<h2 class="title">Danh sách sản phẩm</h2>

<style>
    /* TITLE */
    .title {
        text-align: center;
        color: #6b4a34;
        margin-bottom: 20px;
    }

    /* SEARCH BAR */
    .search-box {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 25px;
    }

        .search-box input,
        .search-box select {
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
            transition: 0.3s;
        }

        .search-box input {
            width: 250px;
        }

            .search-box input:focus,
            .search-box select:focus {
                border-color: #c9a66b;
                outline: none;
                box-shadow: 0 0 5px rgba(201,166,107,0.5);
            }

    /* BUTTON */
    .btn-custom {
        background: linear-gradient(45deg, #c9a66b, #a67c52);
        color: white;
        border: none;
        padding: 10px 15px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-custom:hover {
            background: #8b5e3c;
            transform: translateY(-2px);
        }

    /* PRODUCT GRID */
    .product-list {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }

    /* CARD */
    .product-card {
        width: 250px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        padding: 12px;
        transition: 0.3s;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        .product-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 10px;
        }

        .product-card h4 {
            margin: 10px 0;
            color: #333;
        }

    .price {
        color: #a67c52;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .product-actions {
        display: flex;
        justify-content: space-between;
        gap: 5px;
    }

        .product-actions a {
            flex: 1;
            text-align: center;
            font-size: 13px;
        }

    .pagination {
        text-align: center;
        margin-top: 25px;
    }

        .pagination a {
            display: inline-block;
            padding: 8px 14px;
            margin: 0 5px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            background: linear-gradient(45deg, #c9a66b, #a67c52);
            color: white;
            transition: 0.3s;
        }

            .pagination a:hover {
                background: #8b5e3c;
                transform: translateY(-2px);
            }

        .pagination span {
            margin: 0 10px;
            font-weight: bold;
            color: #6b4a34;
        }

        /* DISABLED */
        .pagination .disabled {
            background: #ccc;
            color: #666;
            pointer-events: none;
            cursor: not-allowed;
        }
</style>

<!-- SEARCH -->
<form method="get" action="/Product" class="search-box">
    <input type="text" name="searchValue" placeholder="Nhập tên sản phẩm..." />

    <select name="priceRange">
        <option value="">-- Chọn giá --</option>
        <option value="1000000-5000000">1 - 5 triệu</option>
        <option value="5000000-10000000">5 - 10 triệu</option>
        <option value="10000000-50000000">10 - 50 triệu</option>
        <option value="50000000-999999999">Trên 50 triệu</option>
    </select>

    <button type="submit" class="btn-custom">Tìm kiếm</button>
</form>

<!-- PRODUCT LIST -->
<div class="product-list">
    @foreach (var p in Model)
    {
        <div class="product-card">

            <img src="~/images/products/@(string.IsNullOrEmpty(p.Photo) ? "nophoto.png" : p.Photo)"
                 style="width:100%;" />
            <h4>@p.ProductName</h4>

            <p class="price">
                @p.Price.ToString("N0") VNĐ
            </p>

            <div class="product-actions">
                <a class="btn-custom" href="/Product/Details/@p.ProductID">
                    Chi tiết📝
                </a>

                <a class="btn-custom" href="/Cart/Add/@p.ProductID">
                    Thêm 🛒
                </a>
            </div>
            

        </div>

    }
</div>
<div class="pagination">

    <!-- TRANG TRƯỚC -->
    <a href="?page=@(ViewBag.Page - 1)"
           class="@(ViewBag.Page <= 1 ? "disabled" : "")">
        ← Trang trước
    </a>

    <!-- CURRENT -->
    <span>Trang @ViewBag.Page</span>

    <!-- TRANG SAU -->
    <a href="?page=@(ViewBag.Page + 1)">
        Trang sau →
    </a>

</div>
@if (TempData["Message"] != null)
{
    <div id="msg" style="background:#d4edda;color:#155724;padding:10px;margin-bottom:10px;">
        @TempData["Message"]
    </div>

    <style>
        #msg {
            transition: opacity 0.5s;
        }
    </style>

    <script>
        setTimeout(function () {
            var el = document.getElementById("msg");
            if (el) {
                el.style.opacity = "0";
                setTimeout(() => el.style.display = "none", 500);
            }
        }, 2000);
    </script>
}

@model List<SV22T1020674.Models.CartItem>

<style>
    .cart-wrapper {
        max-width: 900px;
        margin: 40px auto;
    }

    .cart-title {
        text-align: center;
        color: #5a3e2b;
        margin-bottom: 20px;
    }

    .cart-card {
        background: #fff;
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }

        .cart-table th {
            background: #f5f1e6;
            color: #5a3e2b;
            padding: 10px;
            text-align: center;
        }

        .cart-table td {
            padding: 12px;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

        .cart-table tr:hover {
            background: #faf7f0;
        }

    /* ===== SỐ LƯỢNG (ĐÃ FIX ĐẸP) ===== */
    .qty {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }

        .qty a {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #c9a66b;
            color: white;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
            font-size: 16px;
            transition: 0.2s;
        }

            .qty a:hover {
                background: #8b5e3c;
            }

        .qty span {
            min-width: 30px;
            text-align: center;
            font-weight: bold;
            font-size: 15px;
        }

    .remove {
        color: red;
        text-decoration: none;
        font-weight: bold;
    }

        .remove:hover {
            text-decoration: underline;
        }

    .cart-total {
        text-align: right;
        margin-top: 20px;
        font-size: 18px;
        color: #5a3e2b;
        font-weight: bold;
    }

    .cart-actions {
        margin-top: 20px;
        display: flex;
        justify-content: space-between;
    }

    .btn-custom {
        background: linear-gradient(45deg, #c9a66b, #a67c52);
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-custom:hover {
            background: #8b5e3c;
            transform: translateY(-2px);
        }

    .btn-danger {
        background: linear-gradient(45deg, #e74c3c, #c0392b);
    }

        .btn-danger:hover {
            background: #922b21;
        }

    /* POPUP */
    .confirm-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.45);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .confirm-box {
        background: #fff;
        padding: 26px;
        border-radius: 18px;
        width: 360px;
        text-align: center;
        box-shadow: 0 20px 40px rgba(0,0,0,0.25);
    }

        .confirm-box h3 {
            color: #c0392b;
            margin-bottom: 10px;
        }

    .confirm-actions {
        margin-top: 20px;
        display: flex;
        justify-content: center;
        gap: 12px;
    }

    .btn-ok {
        background: linear-gradient(45deg, #e74c3c, #c0392b);
        color: #fff;
        border: none;
        padding: 9px 24px;
        border-radius: 25px;
    }

        .btn-ok:hover {
            background: #922b21;
        }

    .btn-cancel {
        background: #e5cfc5;
        border: none;
        padding: 9px 24px;
        border-radius: 25px;
    }

        .btn-cancel:hover {
            background: #d6b8ac;
        }
</style>

<div class="cart-wrapper">

    <h2 class="cart-title">🛒 Giỏ hàng</h2>

    <div class="cart-card">

        <table class="cart-table">
            <tr>
                <th>Tên</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
                <th>Hành động</th>
            </tr>

            @{
                decimal total = 0;
            }

            @foreach (var item in Model)
            {
                var money = item.Price * item.Quantity;
                total += money;

                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Price.ToString("N0") đ</td>

                    <td class="qty">
                        <a href="/Cart/Decrease/@item.ProductID">-</a>
                        <span>@item.Quantity</span>
                        <a href="/Cart/Increase/@item.ProductID">+</a>
                    </td>

                    <td>@money.ToString("N0") đ</td>

                    <td>
                        <a href="/Cart/Remove/@item.ProductID" class="remove">
                            ❌ Xóa
                        </a>
                    </td>
                </tr>
            }
        </table>

        <div class="cart-total">
            💰 Tổng tiền: @total.ToString("N0") VNĐ
        </div>

        @if (Model.Count > 0)
        {
            <div class="cart-actions">

                <a href="/Product" class="btn-custom">
                    ← Tiếp tục mua sắm
                </a>

                <div>
                    <a href="/Cart/Clear"
                           class="btn-custom btn-danger"
                           onclick="handleClearCart(event, this)">
                        🗑 Xóa giỏ hàng
                    </a>

                    <a href="/Cart/Checkout" class="btn-custom">
                        🛒 Đặt hàng
                    </a>
                </div>

            </div>
        }

    </div>

</div>

<!-- POPUP -->
<div id="confirmClearCart" class="confirm-overlay">
    <div class="confirm-box">
        <h3>🗑 Xóa giỏ hàng</h3>
        <p>Bạn có chắc muốn xóa toàn bộ giỏ hàng không?</p>

        <div class="confirm-actions">
            <button id="btnOk" class="btn-ok">Xóa</button>
            <button id="btnCancel" class="btn-cancel">Huỷ</button>
        </div>
    </div>
</div>

<script>
    let clearCartUrl = "";

    function handleClearCart(e, el) {
        e.preventDefault();
        clearCartUrl = el.href;
        document.getElementById("confirmClearCart").style.display = "flex";
    }

    document.getElementById("btnOk").onclick = function () {
        window.location.href = clearCartUrl;
    };

    document.getElementById("btnCancel").onclick = function () {
        document.getElementById("confirmClearCart").style.display = "none";
    };
</script>
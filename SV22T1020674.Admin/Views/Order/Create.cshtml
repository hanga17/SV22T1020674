@model SV22T1020674.Models.Sales.CreateOrderViewModel
@using SV22T1020674.Session
@using SV22T1020674.Models.Sales


@{
    ViewBag.Title = "Lập đơn hàng";

    var cart = CartSession.GetCart(Context.Session);
    int index = 1;
}

<div class="row">
    <!-- LEFT: TÌM SẢN PHẨM -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">

                <!-- SEARCH -->
                <form method="get" class="mb-3">
                    <div class="input-group">
                        <input class="form-control"
                               name="searchValue"
                               value="@Model.SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- LIST PRODUCT -->
                @if (Model.Products != null && Model.Products.Count > 0)
                {
                    foreach (var item in Model.Products)
                    {
                        <form method="post" action="~/Order/AddToCart" class="border rounded p-2 mb-2">

                            <strong>@item.ProductName</strong>

                            <div class="row mt-2">
                                <div class="col-4">
                                    <img src="/shop/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                         class="img-fluid border"
                                         style="max-height:100px" />
                                </div>

                                <div class="col-8">
                                    <div class="row g-2">

                                        <div class="col-7">
                                            <label class="form-label mb-0">Giá</label>
                                            <input name="salePrice"
                                                   class="form-control form-control-sm"
                                                   value="@item.Price" />
                                        </div>

                                        <div class="col-5">
                                            <label class="form-label mb-0">SL</label>
                                            <input name="quantity"
                                                   type="number"
                                                   min="1"
                                                   value="1"
                                                   class="form-control form-control-sm" />
                                        </div>
                                    </div>

                                    <input type="hidden" name="productID" value="@item.ProductID" />

                                    <button class="btn btn-sm btn-primary mt-2 w-100">
                                        <i class="bi bi-cart-plus"></i>
                                        Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                }
                else
                {
                    <div class="text-center text-muted">
                        Không tìm thấy mặt hàng
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- RIGHT: GIỎ HÀNG -->
    <div class="col-8">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-cart"></i>
                    Danh sách mặt hàng đã chọn
                </h5>
            </div>

            <div class="card-body">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-success">
                        <tr>
                            <th class="text-center">#</th>
                            <th>Tên hàng</th>
                            <th class="text-center">ĐVT</th>
                            <th class="text-center">SL</th>
                            <th class="text-end">Giá</th>
                            <th class="text-end">Thành tiền</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (cart.Count > 0)
                        {
                            foreach (var item in cart)
                            {
                                <tr>
                                    <td class="text-center">@index</td>
                                    <td>@item.ProductName</td>
                                    <td class="text-center">@item.Unit</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.SalePrice.ToString("N0")</td>
                                    <td class="text-end">@item.Total.ToString("N0")</td>

                                    <!-- ✅ FIX: thêm onclick -->
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-danger"
                                               href="~/Order/DeleteCartItem?productID=@item.ProductID"
                                               onclick="openModal(event, this)">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>

                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted">
                                    Giỏ hàng trống
                                </td>
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr>
                            <th colspan="5" class="text-end">Tổng cộng:</th>
                            <th class="text-end text-danger">
                                @cart.Sum(x => x.Total).ToString("N0")
                            </th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>

                <!-- ❌ XÓA BUG: bỏ ở đây -->
                <div class="text-end">
                    <a class="btn btn-sm btn-danger mt-2"
                           href="~/Order/ClearCart"
                           onclick="openModal(event, this)">
                        <i class="bi bi-trash"></i>
                        Xóa giỏ hàng
                    </a>
                </div>
            </div>
        </div>

        <!-- FORM KHÁCH HÀNG -->
        <div class="card card-outline card-info mt-3">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-person"></i>
                    Thông tin khách hàng & nơi giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form method="post" action="~/Order/SaveOrder">

                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label">Khách hàng</label>
                        <div class="col-md-10">
                            <select class="form-select" name="CustomerID">
                                <option value="">-- Chọn khách hàng --</option>

                                @if (ViewBag.Customers != null)
                                {
                                    foreach (var c in ViewBag.Customers)
                                    {
                                        <option value="@c.CustomerID">@c.CustomerName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                        <div class="col-md-10">
                            <select class="form-select" name="DeliveryProvince">
                                <option value="">-- Chọn Tỉnh/thành --</option>

                                @if (ViewBag.Provinces != null)
                                {
                                    foreach (var p in ViewBag.Provinces)
                                    {
                                        <option value="@p.ProvinceName">@p.ProvinceName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-2 col-form-label">Địa chỉ</label>
                        <div class="col-md-10">
                            <textarea class="form-control" name="DeliveryAddress"></textarea>
                        </div>
                    </div>

                    <div class="text-end">
                        <button class="btn btn-primary">
                            <i class="bi bi-check-circle"></i>
                            Lập đơn hàng
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
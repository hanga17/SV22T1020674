@using SV22T1020674.Models.Partner

@{
    Layout = null;
    var shippers = ViewBag.Shippers as List<Shipper>;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Shipping</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
            body {
                background-color: #f1f5f9;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .modal-content {
                border-radius: 10px;
                border: 1px solid #dee2e6;
                background: #ffffff;
                width: 420px;
            }

            .modal-header {
                border-bottom: 1px solid #e5e7eb;
                padding: 12px 16px;
            }

            .modal-title {
                font-size: 18px;
                font-weight: 600;
            }

            .modal-body {
                padding: 16px;
            }

            .modal-footer {
                border-top: 1px solid #e5e7eb;
                padding: 12px 16px;
            }
    </style>
</head>

<body>

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-sm">

            <!-- HEADER -->
            <div class="modal-header">
                <div class="modal-title">
                    <i class="bi bi-truck"></i>
                    Chọn người giao hàng
                </div>
            </div>

            <!-- FORM (QUAN TRỌNG) -->
            <form method="post" action="~/Admin/Order/Shipping">

                <!-- hidden orderID -->
                <input type="hidden" name="id" value="@ViewBag.OrderID" />

                <!-- BODY -->
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Người giao hàng</label>

                        <select name="shipperID" class="form-select" required>
                            <option value="">-- Chọn người giao hàng --</option>

                            @if (shippers != null && shippers.Count > 0)
                            {
                                foreach (var s in shippers)
                                {
                                    <option value="@s.ShipperID">
                                        @s.ShipperName
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer d-flex justify-content-end gap-2">

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-bicycle"></i> Giao hàng
                    </button>

                    <a href="~/Admin/Order" class="btn btn-light">
                        Đóng
                    </a>

                </div>

            </form>

        </div>
    </div>

</body>
</html>

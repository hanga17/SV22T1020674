@model SV22T1020674.Models.Common.PagedResult<SV22T1020674.Models.Partner.Customer>

@{
    ViewBag.Title = "Quản lý Khách hàng";
}
@section PageToolBar {
    <a href="~/Customer/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Customer" method="get">
            <div class="input-group">
                <input type="text" name="searchValue"
                       class="form-control"
                       value="@ViewBag.SearchValue"
                       placeholder="Tên khách hàng..." autofocus />
                <button type="submit" class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> khách hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên khách hàng</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.CustomerName</td>
                        <td>@item.ContactName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td>@item.Province</td>
                        <td class="text-center">
                            @if (item.IsLocked == true)
                            {
                                <span class="badge bg-danger">Khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Customer/Edit/@item.CustomerID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Customer/Delete/@item.CustomerID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a href="~/Customer/ChangePassword/@item.CustomerID" class="btn btn-sm btn-warning ms-1">
                                <i class="bi bi-key"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer text-center">
        <ul class="pagination justify-content-center flex-wrap mb-0">

            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" href="~/Customer?page=@(Model.Page - 1)&searchValue=@ViewBag.SearchValue">&laquo; Trước</a>
            </li>

            @for (int p = 1; p <= Model.PageCount; p++)
            {
                if (p == 1 || p == Model.PageCount || (p >= Model.Page - 2 && p <= Model.Page + 2))
                {
                    if (p == Model.Page)
                    {
                        <li class="page-item active">
                            <a class="page-link" href="#">@p</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="~/Customer?page=@p&searchValue=@ViewBag.SearchValue">@p</a>
                        </li>
                    }
                }
                else if (p == Model.Page - 3 || p == Model.Page + 3)
                {
                    <li class="page-item disabled">
                        <a class="page-link" href="#">...</a>
                    </li>
                }
            }

            <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                <a class="page-link" href="~/Customer?page=@(Model.Page + 1)&searchValue=@ViewBag.SearchValue">Sau &raquo;</a>
            </li>

        </ul>
    </div>
</div>
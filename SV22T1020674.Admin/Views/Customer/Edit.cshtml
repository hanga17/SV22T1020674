@model SV22T1020674.Models.Partner.Customer

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">    
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2"></i>
                    @ViewBag.Title
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Customer/Save">

                    <input type="hidden" asp-for="CustomerID" />

                    @Html.ValidationMessage("Error", new { @class = "text-danger d-block mb-3" })

                    <div class="row align-items-start">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên khách hàng</label>
                            <input type="text" class="form-control" asp-for="CustomerName" placeholder="Nhập tên khách hàng" autofocus />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên giao dịch</label>
                            <input type="text" class="form-control" asp-for="ContactName" placeholder="Nhập tên giao dịch" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="IsLocked" id="IsLocked" value="true" @(Model.IsLocked == true ? "checked" : "") />
                                <input type="hidden" name="IsLocked" value="false" />
                                <label class="form-check-label" for="IsLocked">
                                    Tài khoản bị khóa
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row align-items-start">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input type="tel" class="form-control" asp-for="Phone" placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-7 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" asp-for="Email" placeholder="Nhập email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea class="form-control" rows="3" asp-for="Address" placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select class="form-select" asp-for="Province" asp-items="await SV22T1020674.Admin.SelectListHelper.Provinces()">
                        </select>
                        <span asp-validation-for="Province" class="text-danger"></span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
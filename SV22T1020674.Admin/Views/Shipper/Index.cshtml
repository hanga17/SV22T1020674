@model SV22T1020674.Models.Common.PagedResult<SV22T1020674.Models.Partner.Shipper>

@{
    ViewBag.Title = "Quản lý Người giao hàng";
}

@section PageToolBar {
    <a href="~/Shipper/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" asp-action="Index">
            <div class="input-group">
                <input type="text"
                       name="searchValue"
                       value="@ViewBag.SearchValue"
                       class="form-control"
                       placeholder="Tên người giao hàng..." autofocus />
                <button type="submit" class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i> Tìm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> người giao hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên người giao hàng</th>
                    <th>Điện thoại</th>
                    <th class="text-center" style="width:120px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems != null && Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.ShipperName</td>
                            <td>@item.Phone</td>
                            <td class="text-center text-nowrap">
                                <a asp-action="Edit" asp-route-id="@item.ShipperID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ShipperID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* PHÂN TRANG *@
    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @for (int i = 1; i <= Model.PageCount; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchValue="@ViewBag.SearchValue">@i</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>

@model List<SV22T1020674.Models.Catalog.ProductPhoto>

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary"
                               href="~/Product/CreatePhoto/@ViewBag.ProductID">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="https://localhost:7281/images/products/@item.Photo"
                                             class="img-thumbnail"
                                             style="max-height:80px;" />
                                    </td>

                                    <td>@item.Description</td>

                                    <td class="text-center">
                                        @item.DisplayOrder
                                    </td>

                                    <td class="text-center">
                                        @if (item.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>

                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary"
                                               href="~/Product/EditPhoto?photoId=@item.PhotoID&productId=@item.ProductID">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <form method="post" action="~/Product/DeletePhoto" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.PhotoID" />
                                            <input type="hidden" name="productId" value="@item.ProductID" />

                                            <button type="button"
                                                    class="btn btn-sm btn-danger"
                                                    onclick="handleDelete(this)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    Chưa có ảnh
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- POPUP ĐẸP -->
<div id="customConfirm" class="confirm-overlay">
    <div class="confirm-box">
        <h5>Xác nhận xoá</h5>
        <p>Bạn có chắc muốn xoá ảnh này?</p>

        <div class="confirm-actions">
            <button id="btnOk" class="btn-ok">Xoá</button>
            <button id="btnCancel" class="btn-cancel">Huỷ</button>
        </div>
    </div>
</div>

<style>
    .confirm-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .confirm-box {
        background: #fff;
        padding: 25px;
        border-radius: 16px;
        width: 360px;
        text-align: center;
        box-shadow: 0 15px 30px rgba(0,0,0,0.2);
    }

        .confirm-box h5 {
            color: #5a3e2b;
            margin-bottom: 10px;
        }

    .confirm-actions {
        margin-top: 20px;
        display: flex;
        justify-content: center;
        gap: 12px;
    }

    .btn-ok {
        background: #7b4b3a;
        color: #fff;
        border: none;
        padding: 8px 22px;
        border-radius: 25px;
    }

        .btn-ok:hover {
            background: #5a3428;
        }

    .btn-cancel {
        background: #e5cfc5;
        border: none;
        padding: 8px 22px;
        border-radius: 25px;
    }

        .btn-cancel:hover {
            background: #d6b8ac;
        }
</style>

<script>
    let currentForm = null;

    function handleDelete(btn) {
        currentForm = btn.closest("form");
        document.getElementById("customConfirm").style.display = "flex";
    }

    document.getElementById("btnOk").onclick = function () {
        if (currentForm) currentForm.submit();
    };

    document.getElementById("btnCancel").onclick = function () {
        document.getElementById("customConfirm").style.display = "none";
    };
</script>
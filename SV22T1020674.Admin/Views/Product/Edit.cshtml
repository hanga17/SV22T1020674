@model SV22T1020674.Models.Catalog.Product

<h2>Cập nhật thông tin mặt hàng</h2>

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" enctype="multipart/form-data">

                    <!-- ID -->
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <!-- TÊN -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="ProductName"
                                   value="@Model.ProductName"
                                   class="form-control"
                                   autofocus />
                        </div>
                    </div>

                    <!-- LOẠI + NCC -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select class="form-select" name="CategoryID">
                                <option value="">-- Chọn loại hàng --</option>

                                @if (Model.CategoryID == 1)
                                {
                                    <option value="1" selected>Áo</option>
                                }
                                else
                                {
                                    <option value="1">Áo</option>
                                }

                                @if (Model.CategoryID == 2)
                                {
                                    <option value="2" selected>Kem</option>
                                }
                                else
                                {
                                    <option value="2">Kem</option>
                                }

                                @if (Model.CategoryID == 3)
                                {
                                    <option value="3" selected>Điện tử</option>
                                }
                                else
                                {
                                    <option value="3">Điện tử</option>
                                }
                            </select>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" name="SupplierID">
                                <option value="">-- Chọn nhà cung cấp --</option>

                                @if (Model.SupplierID == 1)
                                {
                                    <option value="1" selected>Công ty ABC</option>
                                }
                                else
                                {
                                    <option value="1">Công ty ABC</option>
                                }

                                @if (Model.SupplierID == 2)
                                {
                                    <option value="2" selected>Công ty XYZ</option>
                                }
                                else
                                {
                                    <option value="2">Công ty XYZ</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- ĐƠN VỊ + GIÁ -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text"
                                   name="Unit"
                                   value="@Model.Unit"
                                   class="form-control" />
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="number"
                                   name="Price"
                                   value="@Model.Price"
                                   class="form-control" />
                        </div>
                    </div>

                    <!-- TRẠNG THÁI -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsSelling"
                                       value="true"
                                @(Model.IsSelling ? "checked" : "") />
                                <label class="form-check-label">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- ẢNH -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImage(this)" />

                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="https://localhost:7281/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail"
                                     style="max-height:160px;" />
                            </div>
                        </div>
                    </div>

                    <!-- MÔ TẢ -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea name="ProductDescription"
                                      class="form-control"
                                      rows="3">@Model.ProductDescription</textarea>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- PREVIEW -->
<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById("imgPreview").src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

<!-- DANH SÁCH ẢNH PHỤ -->
@{
    await Html.RenderPartialAsync(
        "ListPhotos",
        (List<SV22T1020674.Models.Catalog.ProductPhoto>)ViewBag.Photos
    );
}
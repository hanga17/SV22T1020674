@model List<SV22T1020674.Models.Catalog.Product>
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" asp-controller="Product">
            <div class="row g-2">

                <!-- LOẠI HÀNG -->
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    
                    <select class="form-select" name="categoryId">
                        <option value="">-- Tất cả --</option>
                        @if (ViewBag.CategoryId == 1)
                        {
                            <option value="1" selected>Áo</option>
                        }
                        else
                        {
                            <option value="1">Áo</option>
                        }
                        @if (ViewBag.CategoryId == 2)
                        {
                            <option value="2" selected>Kem</option>
                        }
                        else
                        {
                            <option value="2">Kem</option>
                        }
                    </select>
                </div>

                <!-- NHÀ CUNG CẤP -->
                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" name="supplierId">
                        <option value="">-- Tất cả --</option>
                        @if (ViewBag.CategoryId == 3)
                        {
                            <option value="3" selected>Công ty ABC</option>
                        }
                        else
                        {
                            <option value="3">Công ty ABC</option>
                        }
                        @if (ViewBag.CategoryId == 4)
                        {
                            <option value="3" selected>Công ty XYZ</option>
                        }
                        else
                        {
                            <option value="3">Công ty XYZ</option>
                        }
                    </select>
                </div>

                <!-- GIÁ -->
                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text" name="minPrice" class="form-control" placeholder="Từ" value="@ViewBag.MinPrice" />
                        <span class="input-group-text">-</span>
                        <input type="text" name="maxPrice" class="form-control" placeholder="Đến" value="@ViewBag.MaxPrice" />
                    </div>
                </div>

                <!-- TÊN -->
                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text" name="keyword" class="form-control" placeholder="Tên mặt hàng..." value="@ViewBag.Keyword" />
                        <button type="submit" class="btn btn-info">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.Count</strong> mặt hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:150px;">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <!-- ẢNH (GIỮ NGUYÊN PATH CỦA BẠN) -->
                            <td class="text-center">
                                <img src="/shop/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                     class="img-thumbnail"
                                     style="width:60px;" />
                            </td>

                            <!-- TÊN -->
                            <td>
                                <strong>@item.ProductName</strong>
                            </td>

                            <!-- GIÁ -->
                            <td class="text-end">
                                @item.Price.ToString("N0") VNĐ
                            </td>

                            <!-- TRẠNG THÁI (FIX QUAN TRỌNG) -->
                            <td class="text-center">
                                @if (item.IsSelling)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng bán</span>
                                }
                            </td>

                            <!-- ACTION -->
                            <td class="text-center text-nowrap">
                                <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>

                                <a href="~/Product/Photos/@item.ProductID" class="btn btn-sm btn-info">
                                    Ảnh
                                </a>

                                <a href="~/Product/Attributes/@item.ProductID" class="btn btn-sm btn-warning">
                                    TT
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            Không có dữ liệu
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    <div class="card-footer">
        <ul class="pagination justify-content-center mb-0">

            <!-- PREV -->
            <li class="page-item @(ViewBag.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   href="?page=@(ViewBag.Page - 1)
                   &keyword=@ViewBag.Keyword
                   &categoryId=@ViewBag.CategoryId
                   &supplierId=@ViewBag.SupplierId
                   &minPrice=@ViewBag.MinPrice
                   &maxPrice=@ViewBag.MaxPrice">
                    «
                </a>
            </li>

            <!-- PAGE -->
            @for (int i = 1; i <= ViewBag.PageCount; i++)
            {
                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                    <a class="page-link"
                       href="?page=@i
                       &keyword=@ViewBag.Keyword
                       &categoryId=@ViewBag.CategoryId
                       &supplierId=@ViewBag.SupplierId
                       &minPrice=@ViewBag.MinPrice
                       &maxPrice=@ViewBag.MaxPrice">
                        @i
                    </a>
                </li>
            }

            <!-- NEXT -->
            <li class="page-item @(ViewBag.Page >= ViewBag.PageCount ? "disabled" : "")">
                <a class="page-link"
                   href="?page=@(ViewBag.Page + 1)
                   &keyword=@ViewBag.Keyword
                   &categoryId=@ViewBag.CategoryId
                   &supplierId=@ViewBag.SupplierId
                   &minPrice=@ViewBag.MinPrice
                   &maxPrice=@ViewBag.MaxPrice">
                    »
                </a>
            </li>

        </ul>
    </div>
</div>